# ── Backend Staging Environment ─────────────────────────────────────────
# Copy this to .env in the Railway staging environment.
# CRITICAL: All Supabase-related values MUST point to the staging Supabase
# project.  Direct URL and service key changes alone are enough to guarantee
# staging never touches production data.
#
# KEYS IN THIS FILE: All service keys are placeholders (<your-...>).
# The actual values go into Railway environment variables — never commit them.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=staging

# ── Supabase (staging project — MUST be different from production) ─────
SUPABASE_URL=https://<your-staging-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-staging-service-role-key>
DATABASE_URL=postgresql://<your-staging-db-user>:<password>@<host>:5432/postgres

# ── CORS — allow staging frontend ───────────────────────────────────────
ALLOWED_ORIGIN=https://<your-staging-project>-staging.vercel.app
PORT=3002

# ── LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=<your-openrouter-key>

# ── Vector store ────────────────────────────────────────────────────────
PINECONE_API_KEY=<your-pinecone-key>
PINECONE_INDEX_NAME=jobhub-achievements

# ── External APIs ───────────────────────────────────────────────────────
APIFY_API_KEY=<your-apify-key>
GOOGLE_API_KEY=<your-google-api-key>
SERPAPI_KEY=<your-serpapi-key>
FAL_AI_KEY=<your-fal-ai-key>
LLAMA_CLOUD_API_KEY=<your-llama-cloud-key>

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_SECRET_KEY=<your-stripe-secret-key>
MONTHLY_PRICE_ID=price_<your-monthly-price-id>
ANNUAL_PRICE_ID=price_<your-annual-price-id>
STRIPE_THREE_MONTH_PRICE_ID=price_<your-3month-price-id>

# ── Email ───────────────────────────────────────────────────────────────
RESEND_API_KEY=<your-resend-key>
WEBHOOK_SECRET=<your-webhook-secret>

# ── Analytics ───────────────────────────────────────────────────────────
POSTHOG_API_KEY=<your-posthog-personal-key>
POSTHOG_PROJECT_ID=https://us.posthog.com/project/<your-project-id>/

# ── Dev / debug ─────────────────────────────────────────────────────────
DEV_BYPASS_AUTH=false
MAX_DAILY_GENERATIONS=100
SENTRY_DSN=
